generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
}

enum IndustryKey {
  hr
  gym
  school
  restaurant
}

enum PackageName {
  Starter
  Professional
  Enterprise
}

enum HostingMode {
  DEFAULT_SUBDOMAIN
  CUSTOM_DOMAIN
  CLIENT_HOSTED
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  CLIENT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  ONBOARDING
  OFFBOARDING
}

enum OnboardingStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum OffboardingStatus {
  NONE
  INITIATED
  IN_PROGRESS
  COMPLETED
}

enum HrTaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum DocumentCategory {
  CONTRACT
  POLICY
  ID
  CERTIFICATE
  PAYSLIP
  OTHER
}

enum ReviewStatus {
  DRAFT
  SELF_REVIEW
  MANAGER_REVIEW
  COMPLETED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  REMOTE
  ON_LEAVE
}

enum BenefitEnrollmentStatus {
  ACTIVE
  PENDING
  TERMINATED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Business {
  id            String              @id @default(cuid())
  industryKey   IndustryKey
  businessName  String
  accent        String
  packageName   PackageName         @default(Professional)
  hosting       HostingMode         @default(DEFAULT_SUBDOMAIN)
  domain        String              @unique
  status        BusinessStatus      @default(ACTIVE)
  hrModules     Json                @default("{}")
  records       Json
  notifications Json
  users         User[]
  departments   Department[]
  employees     Employee[]
  leaveTypes    LeaveType[]
  leaveRequests LeaveRequest[]
  auditLogs     AuditLog[]
  notificationsDb NotificationEvent[]
  hrDocuments   HrDocument[]
  performanceReviews PerformanceReview[]
  attendanceRecords AttendanceRecord[]
  benefitPlans  BenefitPlan[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([industryKey])
  @@index([updatedAt])
}

model User {
  id              String              @id @default(cuid())
  businessId      String
  business        Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email           String
  name            String
  role            UserRole            @default(CLIENT)
  passwordHash    String
  sessions        Session[]
  employee        Employee?
  reviewedLeaves  LeaveRequest[]      @relation("LeaveReviewer")
  auditLogs       AuditLog[]
  notifications   NotificationEvent[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([businessId, email])
  @@index([email])
  @@index([businessId, role])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Department {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  managerId  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  employees  Employee[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Employee {
  id             String         @id @default(cuid())
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId         String?        @unique
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        Employee?      @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports  Employee[]     @relation("EmployeeManager")
  name           String
  email          String
  title          String?
  employmentType String?
  startDate      DateTime?      @db.Date
  status         EmployeeStatus @default(ACTIVE)
  emergencyPhone String?
  emergencyName  String?
  endDate        DateTime?        @db.Date
  terminationReason String?
  onboardingStatus OnboardingStatus @default(DRAFT)
  offboardingStatus OffboardingStatus @default(NONE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  leaveBalances  LeaveBalance[]
  leaveRequests  LeaveRequest[]
  onboardingTasks OnboardingTask[]
  offboardingTasks OffboardingTask[]
  documents      HrDocument[]
  performanceReviews PerformanceReview[]
  attendanceRecords AttendanceRecord[]
  benefitEnrollments BenefitEnrollment[]

  @@unique([businessId, email])
  @@index([businessId, status])
  @@index([businessId, departmentId])
}

model LeaveType {
  id               String         @id @default(cuid())
  businessId       String
  business         Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name             String
  annualDays       Int            @default(12)
  paid             Boolean        @default(true)
  requiresApproval Boolean        @default(true)
  createdAt        DateTime       @default(now())
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]

  @@unique([businessId, name])
  @@index([businessId])
}

model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year        Int
  allocated   Float     @default(0)
  used        Float     @default(0)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType   @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  fromDate     DateTime    @db.Date
  toDate       DateTime    @db.Date
  days         Float
  reason       String
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?       @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([businessId, status])
  @@index([employeeId])
  @@index([businessId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
}

model NotificationEvent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel    String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, userId, read])
}

model OnboardingTask {
  id          String       @id @default(cuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?    @db.Date
  status      HrTaskStatus @default(PENDING)
  completedAt DateTime?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@index([employeeId, status])
}

model OffboardingTask {
  id          String       @id @default(cuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      HrTaskStatus @default(PENDING)
  completedAt DateTime?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@index([employeeId, status])
}

model HrDocument {
  id           String           @id @default(cuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employeeId   String?
  employee     Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  title        String
  category     DocumentCategory @default(OTHER)
  fileName     String?
  url          String?
  uploadedById String?
  createdAt    DateTime         @default(now())

  @@index([businessId, category])
  @@index([employeeId])
}

model PerformanceReview {
  id          String       @id @default(cuid())
  businessId  String
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewerId  String?
  period      String
  rating      Int?
  goals       String?
  feedback    String?
  status      ReviewStatus @default(DRAFT)
  dueDate     DateTime?    @db.Date
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([businessId, status])
  @@index([employeeId])
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  businessId String
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  checkIn    String?
  checkOut   String?
  note       String?
  createdAt  DateTime         @default(now())

  @@unique([employeeId, date])
  @@index([businessId, date])
}

model BenefitPlan {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  provider    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  enrollments BenefitEnrollment[]

  @@unique([businessId, name])
  @@index([businessId])
}

model BenefitEnrollment {
  id            String                  @id @default(cuid())
  employeeId    String
  employee      Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  benefitPlanId String
  benefitPlan   BenefitPlan             @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)
  status        BenefitEnrollmentStatus @default(PENDING)
  enrolledAt    DateTime?
  createdAt     DateTime                @default(now())

  @@unique([employeeId, benefitPlanId])
  @@index([employeeId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IndustryKey {
  hr
  gym
  school
  restaurant
}

enum PackageName {
  Starter
  Professional
  Enterprise
}

enum HostingMode {
  DEFAULT_SUBDOMAIN
  CUSTOM_DOMAIN
  CLIENT_HOSTED
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  CLIENT
}

model Business {
  id            String      @id @default(cuid())
  industryKey   IndustryKey
  businessName  String
  accent        String
  packageName   PackageName @default(Professional)
  hosting       HostingMode @default(DEFAULT_SUBDOMAIN)
  domain        String      @unique
  records       Json
  notifications Json
  users         User[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([industryKey])
  @@index([updatedAt])
}

model User {
  id           String    @id @default(cuid())
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email        String
  name         String
  role         UserRole  @default(CLIENT)
  passwordHash String
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([businessId, email])
  @@index([email])
  @@index([businessId, role])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
